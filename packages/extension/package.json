{
  "name": "ai-review-loop",
  "displayName": "AI Review Loop",
  "description": "GitLab-MR-style code review for AI-generated commits",
  "version": "0.1.0",
  "publisher": "ai-review-loop",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinrush/ai-review-loop"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "tsc -w",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "cd ../.. && npm run build -w packages/shared && cd packages/extension && npm run build"
  },
  "devDependencies": {
    "@ai-review-loop/shared": "*",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "uuid": "^11.1.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-review-loop",
          "title": "AI Review Loop",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ai-review-loop": [
        {
          "id": "aiReviewLoop.commits",
          "name": "Commits"
        },
        {
          "id": "aiReviewLoop.files",
          "name": "Changed Files"
        },
        {
          "id": "aiReviewLoop.comments",
          "name": "Comments"
        }
      ]
    },
    "commands": [
      {
        "command": "aiReviewLoop.reReview",
        "title": "Re-review (After Rebase)",
        "icon": "$(sync)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.refreshCommits",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.refreshComments",
        "title": "Refresh Comments",
        "icon": "$(refresh)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.refreshAll",
        "title": "Refresh All (Comments + Threads)",
        "icon": "$(refresh)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.openCommentInDiff",
        "title": "Open in Diff",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.addComment",
        "title": "Add Review Comment",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.addGeneralComment",
        "title": "Add General Comment",
        "icon": "$(comment)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.setBaseBranch",
        "title": "Set Base Branch",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.createComment",
        "title": "Save Comment",
        "category": "AI Review Loop",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "aiReviewLoop.resolveComment",
        "title": "Resolve",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.deleteCommentFromTree",
        "title": "Delete Comment",
        "icon": "$(trash)",
        "category": "AI Review Loop"
      },
      {
        "command": "aiReviewLoop.selectBranch",
        "title": "Select Branch",
        "icon": "$(git-branch)",
        "category": "AI Review Loop"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiReviewLoop.reReview",
          "when": "view == aiReviewLoop.commits && aiReviewLoop.hasActiveSession",
          "group": "navigation@2"
        },
        {
          "command": "aiReviewLoop.addGeneralComment",
          "when": "view == aiReviewLoop.commits",
          "group": "navigation@3"
        },
        {
          "command": "aiReviewLoop.refreshCommits",
          "when": "view == aiReviewLoop.commits",
          "group": "navigation@4"
        },
        {
          "command": "aiReviewLoop.selectBranch",
          "when": "view == aiReviewLoop.comments",
          "group": "navigation@1"
        },
        {
          "command": "aiReviewLoop.refreshComments",
          "when": "view == aiReviewLoop.comments",
          "group": "navigation@2"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "aiReviewLoop.addComment",
          "when": "resourceScheme == ai-review-loop"
        }
      ],
      "comments/commentThread/comment": [
        {
          "command": "aiReviewLoop.createComment",
          "group": "inline",
          "when": "commentController == aiReviewLoop"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "aiReviewLoop.createComment",
          "group": "inline",
          "when": "commentController == aiReviewLoop && commentThreadIsEmpty"
        },
        {
          "command": "aiReviewLoop.resolveComment",
          "group": "inline@1",
          "when": "commentController == aiReviewLoop && !commentThreadIsEmpty"
        },
        {
          "command": "aiReviewLoop.deleteComment",
          "group": "inline@2",
          "when": "commentController == aiReviewLoop && !commentThreadIsEmpty"
        }
      ],
      "view/item/context": [
        {
          "command": "aiReviewLoop.deleteCommentFromTree",
          "when": "view == aiReviewLoop.comments && viewItem == commentEntry",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aiReviewLoop.addComment",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && resourceScheme == ai-review-loop"
      }
    ],
    "configuration": {
      "title": "AI Review Loop",
      "properties": {
        "aiReviewLoop.baseBranch": {
          "type": "string",
          "default": "main",
          "description": "The base branch to compare against (e.g. main, master, develop)"
        }
      }
    }
  }
}
